  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationDir": "dist/lib",
    "emitDeclarationOnly": true,
    "rootDir": "src"
  },
  "include": [
    "src/index.ts",
    "src/command.ts"
  ],
  "exclude": [
    "src/__tests__"
  ]
}